<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════ Obsidian Capsule Color System ═══════ -->
    <!-- Base -->
    <SolidColorBrush x:Key="CapsuleBgBrush" Color="#1C1C24" />
    <SolidColorBrush x:Key="CapsuleBorderBrush" Color="#333348" />
    <SolidColorBrush x:Key="PanelBgBrush" Color="#22222C" />
    <SolidColorBrush x:Key="CardBgBrush" Color="#282834" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E2E2EC" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9090A2" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="#686880" />

    <!-- Accent: warm copper / amber -->
    <SolidColorBrush x:Key="AccentBlueBrush" Color="#D4A040" />
    <SolidColorBrush x:Key="AccentBlueHoverBrush" Color="#E0B458" />
    <SolidColorBrush x:Key="AccentBluePressedBrush" Color="#C09030" />
    <SolidColorBrush x:Key="AccentGreenBrush" Color="#54B868" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="#E8A850" />
    <SolidColorBrush x:Key="AccentRedBrush" Color="#E05555" />
    <SolidColorBrush x:Key="DividerBrush" Color="#35354A" />

    <!-- Semantic background tints -->
    <SolidColorBrush x:Key="AccentSubtleBrush" Color="#2A2820" />

    <!-- ═══════ Capsule Text ═══════ -->
    <Style x:Key="CapsuleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ═══════ Panel Title ═══════ -->
    <Style x:Key="PanelTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
    </Style>

    <!-- ═══════ Panel Subtitle ═══════ -->
    <Style x:Key="PanelSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
    </Style>

    <!-- ═══════ Tab Item ═══════ -->
    <Style x:Key="TabItemStyle" TargetType="TabItem">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="Padding" Value="16,8" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TabItem">
                    <Border x:Name="TabBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="Transparent"
                            BorderThickness="0,0,0,2"
                            Padding="{TemplateBinding Padding}"
                            Cursor="Hand">
                        <ContentPresenter Content="{TemplateBinding Header}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#2A2820" />
                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabBorder" Property="Background" Value="#282830" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Primary Button (渐变光泽) ═══════ -->
    <LinearGradientBrush x:Key="PrimaryGradientBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#E0B458" Offset="0" />
        <GradientStop Color="#C89236" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PrimaryGradientHoverBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#EAC270" Offset="0" />
        <GradientStop Color="#D4A040" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PrimaryGradientPressedBrush" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#B88028" Offset="0" />
        <GradientStop Color="#9C6818" Offset="1" />
    </LinearGradientBrush>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Background" Value="{StaticResource PrimaryGradientBrush}" />
        <Setter Property="Foreground" Value="#1C1C24" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}"
                            BorderBrush="#F0CC80"
                            BorderThickness="0,1,0,0">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryGradientHoverBrush}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryGradientPressedBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════ Secondary Button (实色描边) ═══════ -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Background" Value="#2A2A38" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#404058" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#36364A" />
                <Setter Property="BorderBrush" Value="#5A5A78" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#22222E" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════ Ghost Button (小号清除/操作) ═══════ -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Padding" Value="8,3" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="#9090A2" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#353548" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#2A1C1C" />
                <Setter Property="BorderBrush" Value="#80E05555" />
                <Setter Property="Foreground" Value="#E08080" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#3A1818" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════ Switch Toggle ═══════ -->
    <Style x:Key="SwitchToggleStyle" TargetType="ToggleButton">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="SwitchBg"
                            Width="34" Height="18"
                            CornerRadius="9"
                            Background="#3A3A4A">
                        <Ellipse x:Name="SwitchThumb"
                                 Width="14" Height="14"
                                 Fill="#E2E2EC"
                                 HorizontalAlignment="Left"
                                 Margin="2,0,0,0">
                            <Ellipse.Effect>
                                <DropShadowEffect BlurRadius="3" ShadowDepth="1" Opacity="0.25" />
                            </Ellipse.Effect>
                        </Ellipse>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SwitchBg" Property="Background" Value="{StaticResource AccentBlueBrush}" />
                            <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="SwitchThumb" Property="Margin" Value="0,0,2,0" />
                            <Setter TargetName="SwitchThumb" Property="Fill" Value="#1C1C24" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ Preset Button (chips) ═══════ -->
    <Style x:Key="PresetButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="10" />
        <Setter Property="Padding" Value="0,4" />
        <Setter Property="Margin" Value="2,0" />
        <Setter Property="Background" Value="#252531" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="#353548" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="#363650" />
                <Setter Property="BorderBrush" Value="#4E4E68" />
                <Setter Property="Foreground" Value="#E2E2EC" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="#1F1F2A" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════ ComboBox ═══════ -->
    <Style x:Key="CapsuleComboBoxStyle" TargetType="ComboBox">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Height" Value="26" />
        <Setter Property="MaxDropDownHeight" Value="220" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Background" Value="#1E1E2A" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="Padding" Value="8,5" />
                    <Setter Property="Background" Value="#1E1E2A" />
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                    <Setter Property="Cursor" Value="Hand" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter Property="Background" Value="#2A2820" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#2A2820" />
                                        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter Property="Opacity" Value="0.32" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton x:Name="ToggleButton"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"
                                      Focusable="False">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="TbBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="5" />
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TbBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Grid Margin="{TemplateBinding Padding}"
                              IsHitTestVisible="False">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              VerticalAlignment="Center"
                                              Margin="0,0,6,0" />
                            <TextBlock x:Name="Arrow"
                                       Grid.Column="1"
                                       Text="▾"
                                       FontSize="9"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                        <Popup x:Name="Popup"
                               Placement="Bottom"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="False"
                               Focusable="False"
                               PopupAnimation="Slide"
                               StaysOpen="False">
                            <Grid Background="#1E1E2A" Margin="0,2,0,0">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="#1E1E2A"
                                        BorderBrush="{StaticResource DividerBrush}"
                                        BorderThickness="1"
                                        CornerRadius="5">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Arrow" Property="Text" Value="▴" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ TextBox ═══════ -->
    <Style x:Key="CapsuleTextBoxStyle" TargetType="TextBox">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Height" Value="26" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="8,0" />
        <Setter Property="Background" Value="#1E1E2A" />
        <Setter Property="BorderBrush" Value="{StaticResource DividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource AccentBlueBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="5"
                            Padding="{TemplateBinding Padding}">
                        <ScrollViewer x:Name="PART_ContentHost" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════ 日历（深色主题） ═══════ -->
    <Style x:Key="CalendarNavButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="#9090A2" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Width" Value="22" />
        <Setter Property="Height" Value="22" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#2A2820" />
                            <Setter Property="Foreground" Value="#E0B458" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CalendarHeaderButtonStyle" TargetType="Button">
        <Setter Property="Foreground" Value="#E2E2EC" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="b" Background="{TemplateBinding Background}" CornerRadius="4" Padding="6,2">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#2A2820" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CapsuleCalendarDayButtonStyle" TargetType="CalendarDayButton">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#C8C8D6" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarDayButton">
                    <Border x:Name="b" Background="Transparent" CornerRadius="4" Margin="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#2A2820" />
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="b" Property="BorderBrush" Value="#D4A040" />
                            <Setter TargetName="b" Property="BorderThickness" Value="1" />
                            <Setter Property="Foreground" Value="#E0B458" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#D4A040" />
                            <Setter Property="Foreground" Value="#1C1C24" />
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="#585870" />
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Foreground" Value="#3A3A48" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="#3A3A48" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CapsuleCalendarButtonStyle" TargetType="CalendarButton">
        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="#C8C8D6" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarButton">
                    <Border x:Name="b" Background="Transparent" CornerRadius="4" Margin="2" Padding="4">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="b" Property="Background" Value="#2A2820" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CapsuleCalendarItemStyle" TargetType="CalendarItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CalendarItem">
                    <ControlTemplate.Resources>
                        <DataTemplate x:Key="{x:Static CalendarItem.DayTitleTemplateResourceKey}">
                            <TextBlock Text="{Binding}" Foreground="#9090A2" FontSize="10"
                                       FontFamily="Microsoft YaHei UI, Segoe UI"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="0,0,0,2" />
                        </DataTemplate>
                    </ControlTemplate.Resources>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6" Padding="6">
                        <Grid x:Name="PART_Root">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button x:Name="PART_PreviousButton" Grid.Column="0" Content="◀"
                                        Focusable="False"
                                        Style="{StaticResource CalendarNavButtonStyle}" />
                                <Button x:Name="PART_HeaderButton" Grid.Column="1"
                                        Focusable="False"
                                        Style="{StaticResource CalendarHeaderButtonStyle}" />
                                <Button x:Name="PART_NextButton" Grid.Column="2" Content="▶"
                                        Focusable="False"
                                        Style="{StaticResource CalendarNavButtonStyle}" />
                            </Grid>

                            <Grid x:Name="PART_MonthView" Grid.Row="1" Visibility="Visible">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                            </Grid>

                            <Grid x:Name="PART_YearView" Grid.Row="1" Visibility="Hidden">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                            </Grid>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CapsuleCalendarStyle" TargetType="Calendar">
        <Setter Property="Background" Value="#1E1E2A" />
        <Setter Property="BorderBrush" Value="#35354A" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource CapsuleCalendarDayButtonStyle}" />
        <Setter Property="CalendarButtonStyle" Value="{StaticResource CapsuleCalendarButtonStyle}" />
