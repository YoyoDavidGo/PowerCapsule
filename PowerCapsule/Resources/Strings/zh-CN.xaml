    <sys:String x:Key="Btn.Cancel">取消</sys:String>
    <sys:String x:Key="Common.Status">状态：</sys:String>
    <sys:String x:Key="St.NotSet">未设置</sys:String>
    <sys:String x:Key="St.NotOn">未开启</sys:String>
    <sys:String x:Key="St.WakeSet">已设置唤醒</sys:String>
