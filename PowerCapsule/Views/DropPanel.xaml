<UserControl x:Class="PowerCapsule.Views.DropPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="272" Height="296"
             Focusable="True"
             FocusVisualStyle="{x:Null}"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             TextOptions.TextFormattingMode="Display">

    <Border Background="#22222C"
            BorderBrush="#353550"
            BorderThickness="1"
            CornerRadius="11"
            Padding="9"
            RenderOptions.ClearTypeHint="Enabled"
            MouseLeftButtonDown="Root_MouseLeftButtonDown">
        <Border.Resources>
            <SolidColorBrush x:Key="DividerBrush" Color="#35354A" />
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#9090A2" />
            <SolidColorBrush x:Key="AccentBlueBrush" Color="#D4A040" />

            <!-- ═══ 统一字号刻度：标题 12 / 标签 11 / 说明 10 ═══ -->
            <Style x:Key="SectionTitle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Foreground" Value="#E2E2EC" />
            </Style>
            <Style x:Key="FieldLabel" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
            <Style x:Key="ItemTitle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="#E2E2EC" />
            </Style>
            <Style x:Key="Caption" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
                <Setter Property="FontSize" Value="10" />
                <Setter Property="Foreground" Value="#686880" />
            </Style>
        </Border.Resources>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- ═══ 顶部状态摘要 ═══ -->
            <Border Grid.Row="0"
                    Background="#282834"
                    CornerRadius="6"
                    Padding="9,5"
                    Margin="0,0,0,7">
                <WrapPanel>
                    <TextBlock x:Name="SummaryCurrentState"
                               FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="11"
                               Foreground="#C0C0D0"
                               Text="空闲" />
                    <TextBlock x:Name="SummaryNextTask"
                               FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="11"
                               Foreground="#9090A2"
                               Text="" />
                    <TextBlock x:Name="SummaryRemaining"
                               FontFamily="Microsoft YaHei UI, Segoe UI" FontSize="11"
                               Foreground="#D4A040"
                               Text="" />
                </WrapPanel>
            </Border>

            <!-- ═══ Tab 栏 ═══ -->
            <TabControl Grid.Row="1"
                        x:Name="MainTabControl"
                        SelectionChanged="MainTabControl_SelectionChanged"
                        Margin="0,0,0,7"
                        BorderThickness="0"
                        Background="Transparent">
                <TabControl.Resources>
                    <Style TargetType="TabItem">
                        <Setter Property="FontFamily" Value="Microsoft YaHei UI, Segoe UI" />
                        <Setter Property="FontSize" Value="11" />
                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                        <Setter Property="Padding" Value="10,4" />
                        <Setter Property="Background" Value="Transparent" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="Transparent"
                                            BorderThickness="0,0,0,2"
                                            Padding="{TemplateBinding Padding}"
                                            Cursor="Hand">
                                        <ContentPresenter Content="{TemplateBinding Header}"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"
                                                          TextBlock.Foreground="{TemplateBinding Foreground}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#2A2820" />
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="#2A2A35" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TabControl.Resources>

                <!-- 标题栏三等分整个宽度 -->
                <TabControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" />
                    </ItemsPanelTemplate>
                </TabControl.ItemsPanel>

                <!-- 重写模板：让标题栏拉伸占满，三个标签真正等分 -->
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <ItemsPresenter Grid.Row="0" />
                            <Border Grid.Row="1" Margin="0,6,0,0">
                                <ContentPresenter ContentSource="SelectedContent" />
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>

                <!-- ==================== 定时关机 ==================== -->
                <TabItem Header="{DynamicResource Tab.Shutdown}">
                    <Border Background="#1B1B26" CornerRadius="8" Padding="10,9,10,4">
                        <!-- 弹性行：内容块在固定高度内均匀分散 -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 块A：定时 | 倒计时（共享行严格对齐） -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Column="1" Grid.RowSpan="3" Width="1"
                                        Background="#2F2F44" HorizontalAlignment="Center"
                                        Margin="0,2" />

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource Sd.Timed}"
                                           Style="{StaticResource SectionTitle}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="0" Grid.Column="2" Text="{DynamicResource Sd.Countdown}"
                                           Style="{StaticResource SectionTitle}" Margin="0,0,0,6" />

                                <Grid Grid.Row="1" Grid.Column="0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="HourCombo" Grid.Column="0"
                                              Style="{StaticResource CapsuleComboBoxStyle}"
                                              SelectionChanged="ShutdownTime_Changed" />
                                    <TextBlock Grid.Column="1" Text=":" FontSize="12"
                                               Foreground="#686880"
                                               VerticalAlignment="Center" Margin="4,0" />
                                    <ComboBox x:Name="MinuteCombo" Grid.Column="2"
                                              Style="{StaticResource CapsuleComboBoxStyle}"
                                              SelectionChanged="ShutdownTime_Changed" />
                                </Grid>
                                <Grid Grid.Row="1" Grid.Column="2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CountdownMinutesBox" Grid.Column="0"
                                             Text="" Style="{StaticResource CapsuleTextBoxStyle}"
                                             TextChanged="CountdownMinutesBox_TextChanged" />
                                    <TextBlock Grid.Column="1" Text="{DynamicResource Sd.Min}"
                                               Style="{StaticResource FieldLabel}" Margin="5,0,0,0" />
                                </Grid>

                                <ComboBox x:Name="DateModeCombo" Grid.Row="2" Grid.Column="0"
                                          Style="{StaticResource CapsuleComboBoxStyle}"
                                          SelectionChanged="ShutdownDate_Changed"
                                          DropDownOpened="DateCombo_DropOpened"
                                          Margin="0,7,0,0">
                                    <ComboBoxItem Content="{DynamicResource Date.Today}" Tag="Today" IsSelected="True" />
                                    <ComboBoxItem Content="{DynamicResource Date.Tomorrow}" Tag="Tomorrow" />
                                    <ComboBoxItem Content="{DynamicResource Date.DayAfter}" Tag="DayAfter" />
                                    <ComboBoxItem Content="{DynamicResource Date.Custom}" Tag="Custom"
                                                  PreviewMouseLeftButtonUp="ShutdownCustom_Pick" />
                                </ComboBox>
                                <ComboBox x:Name="CountdownPresetCombo" Grid.Row="2" Grid.Column="2"
                                          Style="{StaticResource CapsuleComboBoxStyle}"
                                          SelectionChanged="CountdownPreset_Changed"
                                          Margin="0,7,0,0">
                                    <ComboBoxItem Content="{DynamicResource Pre.Quick}" Tag="0" IsSelected="True" />
                                    <ComboBoxItem Content="{DynamicResource Pre.5}" Tag="5" />
                                    <ComboBoxItem Content="{DynamicResource Pre.10}" Tag="10" />
                                    <ComboBoxItem Content="{DynamicResource Pre.15}" Tag="15" />
                                    <ComboBoxItem Content="{DynamicResource Pre.20}" Tag="20" />
                                    <ComboBoxItem Content="{DynamicResource Pre.30}" Tag="30" />
                                    <ComboBoxItem Content="{DynamicResource Pre.45}" Tag="45" />
                                    <ComboBoxItem Content="{DynamicResource Pre.60}" Tag="60" />
                                    <ComboBoxItem Content="{DynamicResource Pre.90}" Tag="90" />
                                    <ComboBoxItem Content="{DynamicResource Pre.120}" Tag="120" />
                                    <ComboBoxItem Content="{DynamicResource Pre.180}" Tag="180" />
                                    <ComboBoxItem Content="{DynamicResource Pre.240}" Tag="240" />
                                    <ComboBoxItem Content="{DynamicResource Pre.360}" Tag="360" />
                                    <ComboBoxItem Content="{DynamicResource Pre.480}" Tag="480" />
                                </ComboBox>
                            </Grid>

                            <!-- 块B：提醒 -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Sd.Reminder}" Style="{StaticResource FieldLabel}" />
                                <ComboBox x:Name="ReminderCombo" Grid.Column="1"
                                          Style="{StaticResource CapsuleComboBoxStyle}">
                                    <ComboBoxItem Content="{DynamicResource Rem.30}" Tag="30" />
                                    <ComboBoxItem Content="{DynamicResource Rem.60}" Tag="60" IsSelected="True" />
                                    <ComboBoxItem Content="{DynamicResource Rem.180}" Tag="180" />
                                    <ComboBoxItem Content="{DynamicResource Rem.600}" Tag="600" />
                                    <ComboBoxItem Content="{DynamicResource Rem.1800}" Tag="1800" />
                                </ComboBox>
                            </Grid>

                            <!-- 块C：状态 -->
                            <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Common.Status}" Style="{StaticResource Caption}" />
                                <TextBlock x:Name="ShutdownStatusText"
                                           Style="{StaticResource Caption}" Foreground="#9090A2"
                                           Margin="3,0,0,0"
                                           Text="{DynamicResource St.NotSet}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ==================== 防止睡眠 ==================== -->
                <TabItem Header="{DynamicResource Tab.Sleep}">
                    <Border Background="#1B1B26" CornerRadius="8" Padding="10,9,10,4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 防止系统睡眠 -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Sl.PreventTitle}" Style="{StaticResource ItemTitle}" />
                                    <TextBlock Text="{DynamicResource Sl.PreventSub}"
                                               Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                </StackPanel>
                                <ToggleButton x:Name="PreventSleepToggle"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource SwitchToggleStyle}"
                                              Checked="PreventSleepToggle_Changed"
                                              Unchecked="PreventSleepToggle_Changed" />
                            </Grid>

                            <!-- 保持屏幕常亮 -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="{DynamicResource Sl.DisplayTitle}" Style="{StaticResource ItemTitle}" />
                                    <TextBlock Text="{DynamicResource Sl.DisplaySub}"
                                               Style="{StaticResource Caption}" Margin="0,2,0,0" />
                                </StackPanel>
                                <ToggleButton x:Name="KeepDisplayToggle"
                                              Grid.Column="1"
                                              VerticalAlignment="Center"
                                              Style="{StaticResource SwitchToggleStyle}"
                                              Checked="PreventSleepToggle_Changed"
                                              Unchecked="PreventSleepToggle_Changed" />
                            </Grid>

                            <!-- 持续时间 + 自定义 -->
                            <StackPanel Grid.Row="4">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="46" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{DynamicResource Sl.Duration}" Style="{StaticResource FieldLabel}" />
                                    <ComboBox x:Name="DurationCombo" Grid.Column="1"
                                              Style="{StaticResource CapsuleComboBoxStyle}"
                                              SelectionChanged="DurationCombo_SelectionChanged"
                                              DropDownOpened="DurationCombo_DropOpened">
                                        <ComboBoxItem Content="{DynamicResource Dur.Always}" Tag="Always" IsSelected="True" />
                                        <ComboBoxItem Content="{DynamicResource Dur.Minutes30}" Tag="Minutes30" />
                                        <ComboBoxItem Content="{DynamicResource Dur.Hours1}" Tag="Hours1" />
                                        <ComboBoxItem Content="{DynamicResource Dur.Hours2}" Tag="Hours2" />
                                        <ComboBoxItem Content="{DynamicResource Dur.Hours5}" Tag="Hours5" />
                                        <ComboBoxItem Content="{DynamicResource Dur.Hours10}" Tag="Hours10" />
                                        <ComboBoxItem Content="{DynamicResource Dur.Days1}" Tag="Days1" />
                                        <ComboBoxItem Content="{DynamicResource Dur.Days2}" Tag="Days2" />
                                        <ComboBoxItem Content="{DynamicResource Dur.Custom}" Tag="Custom"
                                                      PreviewMouseLeftButtonUp="SleepCustom_Pick" />
                                    </ComboBox>
                                </Grid>
                                <Border x:Name="CustomMinutesPanel" Margin="0,7,0,0"
                                        Visibility="Collapsed"
                                        Background="#2A2418" CornerRadius="6" Padding="8,5">
                                    <TextBlock x:Name="CustomDateLabel"
                                               FontFamily="Microsoft YaHei UI, Segoe UI"
                                               FontSize="10" Foreground="#D4A040" Text="" />
                                </Border>
                            </StackPanel>

                            <!-- 状态 -->
                            <StackPanel Grid.Row="6" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Common.Status}" Style="{StaticResource Caption}" />
                                <TextBlock x:Name="SleepStatusText"
                                           Style="{StaticResource Caption}" Foreground="#9090A2"
                                           Margin="3,0,0,0"
                                           Text="{DynamicResource St.NotOn}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>

                <!-- ==================== 定时唤醒 ==================== -->
                <TabItem Header="{DynamicResource Tab.Wake}">
                    <Border Background="#1B1B26" CornerRadius="8" Padding="10,9,10,4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- 唤醒时间（标签 + 占满，右边缘与“待机”对齐） -->
                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Wk.Time}" Style="{StaticResource FieldLabel}" />
                                <ComboBox x:Name="WakeHourCombo" Grid.Column="1"
                                          Style="{StaticResource CapsuleComboBoxStyle}"
                                          SelectionChanged="WakeTime_Changed" />
                                <TextBlock Grid.Column="2" Text=":" FontSize="12" Foreground="#686880"
                                           VerticalAlignment="Center" Margin="5,0" />
                                <ComboBox x:Name="WakeMinuteCombo" Grid.Column="3"
                                          Style="{StaticResource CapsuleComboBoxStyle}"
                                          SelectionChanged="WakeTime_Changed" />
                            </Grid>

                            <!-- 日期 -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Wk.Date}" Style="{StaticResource FieldLabel}" />
                                <ComboBox x:Name="WakeDateModeCombo" Grid.Column="1"
                                          Style="{StaticResource CapsuleComboBoxStyle}"
                                          SelectionChanged="WakeDate_Changed"
                                          DropDownOpened="WakeCombo_DropOpened">
                                    <ComboBoxItem Content="{DynamicResource Date.Today}" Tag="Today" />
                                    <ComboBoxItem Content="{DynamicResource Date.Tomorrow}" Tag="Tomorrow" IsSelected="True" />
                                    <ComboBoxItem Content="{DynamicResource Date.DayAfter}" Tag="DayAfter" />
                                    <ComboBoxItem Content="{DynamicResource Date.Custom}" Tag="Custom"
                                                  PreviewMouseLeftButtonUp="WakeCustom_Pick" />
                                </ComboBox>
                            </Grid>

                            <!-- 待机：延时进入睡眠 / 休眠 -->
                            <Grid Grid.Row="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="46" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="6" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{DynamicResource Wk.Standby}" Style="{StaticResource FieldLabel}" />
                                <ComboBox x:Name="SleepActionCombo" Grid.Column="1"
                                          Style="{StaticResource CapsuleComboBoxStyle}">
                                    <ComboBoxItem Content="{DynamicResource Act.None}" Tag="None" IsSelected="True" />
                                    <ComboBoxItem Content="{DynamicResource Act.Sleep}" Tag="Sleep" />
                                    <ComboBoxItem Content="{DynamicResource Act.Hibernate}" Tag="Hibernate" />
                                </ComboBox>
                                <ComboBox x:Name="SleepDelayCombo" Grid.Column="3"
                                          Style="{StaticResource CapsuleComboBoxStyle}">
                                    <ComboBoxItem Content="{DynamicResource Dly.0}" Tag="0" IsSelected="True" />
                                    <ComboBoxItem Content="{DynamicResource Dly.3}" Tag="3" />
                                    <ComboBoxItem Content="{DynamicResource Dly.10}" Tag="10" />
                                    <ComboBoxItem Content="{DynamicResource Dly.30}" Tag="30" />
                                    <ComboBoxItem Content="{DynamicResource Dly.60}" Tag="60" />
                                    <ComboBoxItem Content="{DynamicResource Dly.120}" Tag="120" />
                                    <ComboBoxItem Content="{DynamicResource Dly.300}" Tag="300" />
                                    <ComboBoxItem Content="{DynamicResource Dly.600}" Tag="600" />
                                </ComboBox>
                            </Grid>

                            <!-- 提示卡片 -->
                            <Border Grid.Row="6" Background="#2A2418" CornerRadius="6" Padding="8,6">
                                <TextBlock FontFamily="Microsoft YaHei UI, Segoe UI"
                                           FontSize="10" Foreground="#D4A040" TextWrapping="Wrap"
                                           Text="{DynamicResource Wk.Tip}" />
                            </Border>

                            <!-- 状态 -->
                            <StackPanel Grid.Row="8" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="{DynamicResource Common.Status}" Style="{StaticResource Caption}" />
                                <TextBlock x:Name="WakeStatusText"
                                           Style="{StaticResource Caption}" Foreground="#9090A2"
                                           Margin="3,0,0,0"
                                           Text="{DynamicResource St.NotSet}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- ═══ 底部操作栏 ═══ -->
            <Border Grid.Row="2"
                    BorderBrush="#35354A"
                    BorderThickness="0,1,0,0"
                    Padding="0,7,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="6" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{DynamicResource Btn.Apply}" Height="28"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ApplyBtn_Click" />
                    <Button Grid.Column="2" Content="{DynamicResource Btn.Clear}" Height="28"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="ClearTaskBtn_Click" />
                    <Button Grid.Column="4" Content="{DynamicResource Btn.Cancel}" Height="28"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="CancelBtn_Click" />
                </Grid>
            </Border>

            <!-- ═══ 日期选择覆盖层（面板内部，规避独立窗口激活问题） ═══ -->
            <Grid x:Name="DatePickerOverlay" Grid.RowSpan="3"
                  Visibility="Collapsed"
                  Background="#E015151E" Panel.ZIndex="100">
                <Border Background="#22222C" BorderBrush="#3A3A52" BorderThickness="1"
                        CornerRadius="10" Padding="10"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource Dp.Title}" Style="{StaticResource SectionTitle}"
                                   Margin="2,0,0,4" />
                        <Calendar x:Name="OverlayCalendar"
                                  Style="{StaticResource CapsuleCalendarStyle}" />
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="0,8,0,0">
                            <Button Content="{DynamicResource Dp.Ok}" Width="60" Height="26" Margin="0,0,8,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="OverlayOk_Click" />
                            <Button Content="{DynamicResource Dp.Cancel}" Width="60" Height="26"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="OverlayCancel_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Border>
</UserControl>
