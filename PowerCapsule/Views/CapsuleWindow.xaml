<Window x:Class="PowerCapsule.Views.CapsuleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PowerCapsule.Views"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="198" Height="48"
        TextOptions.TextFormattingMode="Display"
        Closing="Window_Closing"
        Loaded="Window_Loaded">

    <!-- 窗口比胶囊大一圈（四周 9px 透明），用于容纳外边缘发光 -->
    <Grid x:Name="RootGrid">
        <!-- 发光/阴影底层：有任务时整圈绿色发光，空闲时普通暗阴影 -->
        <Border x:Name="GlowBorder" Margin="9"
                CornerRadius="15"
                Background="#1C1C24"
                IsHitTestVisible="False">
            <Border.Effect>
                <DropShadowEffect x:Name="GlowEffect" Color="#000000"
                                  BlurRadius="10" ShadowDepth="2" Opacity="0.3" />
            </Border.Effect>
        </Border>

        <!-- 主胶囊 — 始终可见，从不折叠（无 Effect，保持文字清晰） -->
        <Border x:Name="CapsuleBorder" Margin="9"
                CornerRadius="15"
                BorderBrush="#353550"
                BorderThickness="1"
                RenderOptions.ClearTypeHint="Enabled"
                MouseLeftButtonDown="CapsuleBorder_MouseLeftButtonDown"
                MouseEnter="CapsuleBorder_MouseEnter"
                MouseLeave="CapsuleBorder_MouseLeave"
                Cursor="Hand">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#F0222232" Offset="0" />
                    <GradientStop Color="#F01A1A28" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>

            <DockPanel Margin="12,0" VerticalAlignment="Center">
                <!-- 箭头按钮 -->
                <Border x:Name="ArrowButton"
                        DockPanel.Dock="Right"
                        Width="20" Height="20"
                        CornerRadius="10"
                        Background="Transparent"
                        MouseLeftButtonDown="ArrowButton_MouseLeftButtonDown"
                        Cursor="Hand"
                        Margin="4,0,0,0">
                    <TextBlock x:Name="ArrowText"
                               Text="▼"
                               FontSize="8"
                               Foreground="#9090A2"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <!-- 状态文字（占满腾出的中间区域，水平居中） -->
                <TextBlock x:Name="StatusText"
                           Text="空闲 ｜ 点击设置"
                           Style="{StaticResource CapsuleTextStyle}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Stretch"
                           TextAlignment="Center"
                           Margin="0,-1.5,0,0"
                           TextTrimming="CharacterEllipsis" />
            </DockPanel>
        </Border>

        <!-- 边缘竖杠 — 吸附隐藏时作为视觉蒙层；有任务时变绿（背景由代码切换） -->
        <Border x:Name="EdgeBar"
                Width="7" Height="34"
                CornerRadius="3.5"
                Background="#3A3A52"
                Visibility="Collapsed"
                Cursor="Hand"
                MouseEnter="EdgeBar_MouseEnter"
                MouseLeftButtonDown="EdgeBar_MouseLeftButtonDown"
                HorizontalAlignment="Right"
                VerticalAlignment="Center" />
    </Grid>
</Window>
